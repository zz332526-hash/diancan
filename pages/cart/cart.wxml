<view class="cart-wrap"><view class="section-title">购物车</view>
<block wx:if="{{cart.length}}"><block wx:for="{{cart}}" wx:key="id"><view class="card row"><image src="{{item.image}}"/><view class="meta"><view>{{item.name}}</view><view>¥{{item.price}}</view></view><view class="step"><button data-id="{{item.id}}" data-delta="-1" bindtap="changeCount">-</button><text>{{item.count}}</text><button data-id="{{item.id}}" data-delta="1" bindtap="changeCount">+</button></view></view></block><view class="pay">合计 ¥{{total}}</view><button class="go" bindtap="checkout">去支付</button></block><view wx:else class="empty">购物车空空的，去点一杯吧～</view></view>
