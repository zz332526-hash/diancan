.order-page{padding-bottom:120rpx}.top-dark{background:#242424;color:#fff;padding:32rpx}.mode-tabs{font-size:44rpx;display:flex;gap:20rpx;align-items:center}.mode-tabs .active{font-weight:700}.store{font-size:52rpx;margin-top:26rpx}.sub{color:#ccc;margin-top:16rpx}.panel{display:flex;height:calc(100vh - 320rpx)}.left{width:28%;background:#f7f7f7}.cat{padding:34rpx 16rpx;color:#808080}.cat.on{color:#111;font-weight:700;border-left:6rpx solid #111;background:#fff}.right{width:72%;padding:24rpx}.title{font-size:50rpx;font-weight:700;margin-bottom:22rpx}.drink{display:flex;padding:18rpx;margin-bottom:16rpx}.drink image{width:150rpx;height:150rpx;border-radius:12rpx}.meta{flex:1;margin-left:18rpx}.name{font-size:34rpx;font-weight:700}.desc{font-size:24rpx;color:#666;margin:10rpx 0 16rpx}.bottom{display:flex;justify-content:space-between;align-items:center}.price{font-size:40rpx}.bottom button{margin:0;line-height:56rpx;width:56rpx;height:56rpx;border-radius:50%;background:#111;color:#fff}.cart-bar{position:fixed;left:24rpx;right:24rpx;bottom:24rpx;background:#111;color:#fff;text-align:center;padding:24rpx;border-radius:999rpx}
