<view class="checkout"><view class="section-title">确认订单</view><view class="card box"><view class="modes"><button class="{{mode==='pickup'?'on':''}}" data-mode="pickup" bindtap="switchMode">到店取</button><button class="{{mode==='delivery'?'on':''}}" data-mode="delivery" bindtap="switchMode">喜外送</button></view><view class="line">配送方式：{{mode==='pickup'?'到店自取':'外卖配送'}}</view><view class="line">应付金额：<text class="money">¥{{total}}</text></view></view><button class="pay-btn" bindtap="pay">微信支付</button></view>
